<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WoWprojekt</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WoWprojekt.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="left-column">
            <div class="brand-block">
                <div class="crest" aria-hidden="true">F</div>
                <div>
                    <a class="brand-title" asp-controller="Home" asp-action="Index">Raid Chronicle</a>
                    <p class="brand-subtitle">Wrath Preparation Codex</p>
                </div>
            </div>

            <nav class="nav-groups" aria-label="Primary">
                <div class="nav-group">
                    <h2>Classes</h2>
                    <a asp-controller="Encyclopedia" asp-action="Classes" asp-route-id="DeathKnight">Death Knight</a>
                    <a asp-controller="Encyclopedia" asp-action="Classes" asp-route-id="Druid">Druid</a>
                    <a asp-controller="Encyclopedia" asp-action="Classes" asp-route-id="Hunter">Hunter</a>
                    <a asp-controller="Encyclopedia" asp-action="Classes" asp-route-id="Mage">Mage</a>
                    <a asp-controller="Encyclopedia" asp-action="Classes" asp-route-id="Paladin">Paladin</a>
                    <a asp-controller="Encyclopedia" asp-action="Classes" asp-route-id="Priest">Priest</a>
                    <a asp-controller="Encyclopedia" asp-action="Classes" asp-route-id="Rogue">Rogue</a>
                    <a asp-controller="Encyclopedia" asp-action="Classes" asp-route-id="Shaman">Shaman</a>
                    <a asp-controller="Encyclopedia" asp-action="Classes" asp-route-id="Warlock">Warlock</a>
                    <a asp-controller="Encyclopedia" asp-action="Classes" asp-route-id="Warrior">Warrior</a>
                    <a asp-controller="Encyclopedia" asp-action="Talents" asp-route-id="1">Talent Compendium</a>
                </div>

                <div class="nav-group">
                    <h2>Raids</h2>
                    <a asp-controller="Encyclopedia" asp-action="Raids" asp-route-id="1">Icecrown Citadel</a>
                    <a asp-controller="Encyclopedia" asp-action="Raids" asp-route-id="2">Trial of the Grand Crusader</a>
                    <a asp-controller="Encyclopedia" asp-action="Raids" asp-route-id="3">Ruby Sanctum</a>
                    <a asp-controller="Encyclopedia" asp-action="Bosses" asp-route-id="1">Boss Archives</a>
                </div>
                <div class="nav-group">
                    <h2>Professions</h2>
                    <a asp-controller="Encyclopedia" asp-action="Professions" asp-route-id="1">Blacksmithing</a>
                    <a asp-controller="Encyclopedia" asp-action="Professions" asp-route-id="2">Jewelcrafting</a>
                    <a asp-controller="Encyclopedia" asp-action="Professions" asp-route-id="3">Tailoring</a>
                    <a asp-controller="Encyclopedia" asp-action="Professions" asp-route-id="4">Enchanting</a>
                    <a asp-controller="Encyclopedia" asp-action="PlayerProfessions" asp-route-playerId="1" asp-route-professionId="1">Player Links</a>
                </div>

                <div class="nav-group">
                    <h2>Guilds</h2>
                    <a asp-controller="Encyclopedia" asp-action="Guilds" asp-route-id="1">Guild Register</a>
                </div>
            </nav>
        </aside>

        <main class="center-column" role="main">
            @RenderBody()
        </main>

        <aside class="right-column">
            @RenderSection("RightPanel", required: false)
        </aside>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
